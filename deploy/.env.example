# Copy to .env on the server (/opt/sollicitations/.env). NEVER commit the real file.
#
# The deploy workflows overwrite ONLY the WEB_IMAGE / API_IMAGE lines (SHA-pinned)
# on each deploy and preserve everything else — so the Postgres secrets below live
# only on the server and are set once at bootstrap.

# Image tags (placeholders; CI replaces with ghcr.io/...:<sha>)
WEB_IMAGE=ghcr.io/typhion/sollicitations-web:latest
API_IMAGE=ghcr.io/typhion/sollicitations-api:latest

# Postgres — set a strong, random password on the server
POSTGRES_DB=sollicitations
POSTGRES_USER=sollicitations
POSTGRES_PASSWORD=change-me-to-a-long-random-secret
